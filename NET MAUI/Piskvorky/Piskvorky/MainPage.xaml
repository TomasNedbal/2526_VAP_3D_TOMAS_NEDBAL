<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Piskvorky.MainPage">

    <Grid RowDefinitions="Auto,*,Auto" Padding="10">

        <Button Text="Přepnout tmavý režim"
                Clicked="ToggleTheme"
                Margin="0,0,0,10"/>

        <Grid Grid.Row="1"
              x:Name="Board"
              RowDefinitions="*,*,*"
              ColumnDefinitions="*,*,*">

            <Button Grid.Row="0" Grid.Column="0" Clicked="Play" BorderColor="Black" BorderWidth="1" FontSize="32"/>
            <Button Grid.Row="0" Grid.Column="1" Clicked="Play" BorderColor="Black" BorderWidth="1" FontSize="32"/>
            <Button Grid.Row="0" Grid.Column="2" Clicked="Play" BorderColor="Black" BorderWidth="1" FontSize="32"/>

            <Button Grid.Row="1" Grid.Column="0" Clicked="Play" BorderColor="Black" BorderWidth="1" FontSize="32"/>
            <Button Grid.Row="1" Grid.Column="1" Clicked="Play" BorderColor="Black" BorderWidth="1" FontSize="32"/>
            <Button Grid.Row="1" Grid.Column="2" Clicked="Play" BorderColor="Black" BorderWidth="1" FontSize="32"/>

            <Button Grid.Row="2" Grid.Column="0" Clicked="Play" BorderColor="Black" BorderWidth="1" FontSize="32"/>
            <Button Grid.Row="2" Grid.Column="1" Clicked="Play" BorderColor="Black" BorderWidth="1" FontSize="32"/>
            <Button Grid.Row="2" Grid.Column="2" Clicked="Play" BorderColor="Black" BorderWidth="1" FontSize="32"/>

        </Grid>

        <Button Grid.Row="2"
                Text="Reset"
                Clicked="ResetGame"
                Margin="0,10,0,0"/>
    </Grid>

</ContentPage>